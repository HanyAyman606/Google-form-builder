<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.formbuilder.ui.MainWindowController"
            fx:id="rootPane">

  <top>
    <VBox>
      <MenuBar>
        <Menu text="File">
          <MenuItem text="New Project…"    onAction="#onNew"/>
          <MenuItem text="Open Project…"   onAction="#onOpen"/>
          <SeparatorMenuItem/>
          <MenuItem text="Save"            onAction="#onSave"/>
          <MenuItem text="Save As…"        onAction="#onSaveAs"/>
          <SeparatorMenuItem/>
          <MenuItem text="Back to Welcome" onAction="#onBackToWelcome"/>
        </Menu>
      </MenuBar>
      <HBox styleClass="title-bar" alignment="CENTER_LEFT">
        <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
        <Label fx:id="titleLabel" text="Perfection Forms Builder"
               styleClass="title-bar-label"/>
      </HBox>
    </VBox>
  </top>

  <left>
    <VBox fx:id="sidebarVBox" styleClass="sidebar" spacing="4"
          visible="false" managed="false">
      <padding><Insets top="20" right="8" bottom="20" left="8"/></padding>
      <Label text="WORKFLOW" styleClass="sidebar-section-label"/>
      <Button fx:id="btnImport"   text="Import"    onAction="#onImport"
              maxWidth="Infinity" styleClass="sidebar-btn,sidebar-active"/>
      <Button fx:id="btnEditor"   text="Edit"      onAction="#onEditor"
              maxWidth="Infinity" styleClass="sidebar-btn"/>
      <Button fx:id="btnSections" text="Sections"  onAction="#onSections"
              maxWidth="Infinity" styleClass="sidebar-btn"/>
      <Button fx:id="btnAnswers"  text="Answers"   onAction="#onAnswers"
              maxWidth="Infinity" styleClass="sidebar-btn"/>
      <Button fx:id="btnExport"   text="Publish"   onAction="#onExport"
              maxWidth="Infinity" styleClass="sidebar-btn"/>
      <Separator style="-fx-opacity:0.3;"/>
      <Label text="TOOLS" styleClass="sidebar-section-label"/>
      <Button fx:id="btnBank" text="Question Bank" onAction="#onBank"
              maxWidth="Infinity" styleClass="sidebar-btn"/>
    </VBox>
  </left>

  <center>
    <StackPane fx:id="contentArea"/>
  </center>

  <bottom>
    <HBox styleClass="status-bar" spacing="12" alignment="CENTER_LEFT">
      <padding><Insets top="5" right="12" bottom="5" left="12"/></padding>
      <ProgressBar fx:id="progressBar" prefWidth="160" prefHeight="12" visible="false"/>
      <Label fx:id="statusLabel" text="Ready" styleClass="status-label"/>
    </HBox>
  </bottom>

</BorderPane>
